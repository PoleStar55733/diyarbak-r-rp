    <div class="admin-tab-content" id="tab-duyuru">
      <div class="list-edit" id="ap-ann"></div>
      <button class="btn-add" onclick="addAnn()">+ Duyuru Ekle</button>
    </div>

    <!-- KURALLAR -->
    <div class="admin-tab-content" id="tab-kural">
      <div class="list-edit" id="ap-rules"></div>
      <button class="btn-add" onclick="addRule()">+ Kural Ekle</button>
    </div>

    <!-- SSS -->
    <div class="admin-tab-content" id="tab-faq">
      <div class="list-edit" id="ap-faq"></div>
      <button class="btn-add" onclick="addFaq()">+ Soru Ekle</button>
    </div>

    <!-- GALERİ -->
    <div class="admin-tab-content" id="tab-galeri">
      <p style="color:var(--muted);font-size:.88rem;margin-bottom:16px">Görsel URL'si (imgur, discord cdn vb.) ve etiket yaz.</p>
      <div class="list-edit" id="ap-gallery"></div>
      <button class="btn-add" onclick="addGallery()">+ Görsel Ekle</button>
    </div>

    <!-- LİDERLİK -->
    <div class="admin-tab-content" id="tab-lb">
      <div class="list-edit" id="ap-lb"></div>
      <button class="btn-add" onclick="addLb()">+ Oyuncu Ekle</button>
    </div>

    <!-- EKİP -->
    <div class="admin-tab-content" id="tab-ekip">
      <div class="list-edit" id="ap-staff"></div>
      <button class="btn-add" onclick="addStaff()">+ Üye Ekle</button>
    </div>

    <!-- KARAKTERLERs -->
    <div class="admin-tab-content" id="tab-karakter">
      <div class="list-edit" id="ap-chars"></div>
      <button class="btn-add" onclick="addChar()">+ Karakter Ekle</button>
    </div>

    <!-- HARİTA -->
    <div class="admin-tab-content" id="tab-harita">
      <div class="admin-section">
        <label>Harita Görseli URL (imgur, discord CDN vb.)</label>
        <input id="ap-mapUrl" type="text" placeholder="https://..."/>
      </div>
      <div class="admin-section">
        <label>Harita Başlığı</label>
        <input id="ap-mapLabel" type="text"/>
      </div>
    </div>

    <!-- BAŞVURULAR -->
    <div class="admin-tab-content" id="tab-basvurular">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <span style="color:var(--muted);font-size:.85rem">Gelen başvurular burada listelenir.</span>
        <button class="btn-remove" onclick="clearApplications()">Tümünü Sil</button>
      </div>
      <div id="ap-basvurular-list"></div>
    </div>

    <div class="admin-btns">
      <button class="btn btn-ghost" onclick="closeAdmin()">İptal</button>
      <button class="btn btn-primary" onclick="saveAdmin()">Kaydet</button>
    </div>
  </div>
</div>

<script>
/* =================== RENDER =================== */
function loadConfig(){
  const s=localStorage.getItem('dyrp_cfg');
  if(s){const p=JSON.parse(s);Object.keys(p).forEach(k=>CONFIG[k]=p[k])}
  const sp=localStorage.getItem('dyrp_pass');
  window._pass=sp||ADMIN_PASSWORD;
}

function applyConfig(){
  const c=CONFIG;
  document.title=c.gameName;
  setText('nav-logo',c.gameName);setText('hero-title',c.gameName);setText('hero-desc',c.gameDesc);
  setText('owner-av',c.ownerRoblox.charAt(0).toUpperCase());setText('owner-name',c.ownerRoblox);
  setHref('play-btn',c.robloxLink);setHref('roblox-nav',c.robloxLink);setHref('discord-btn',c.discordLink);
  setText('footer-name',c.gameName);setText('footer-owner',c.ownerRoblox);
  // applyTitle ve applySub elementleri HTML'de yok, bu yüzden yorum satırı yapıldı veya eklendi.
  // setText('apply-title-el',c.applyTitle||'Başvuru');
  // setText('apply-sub-el',c.applySub||'');
  renderStats();renderAnn();renderRules();renderFaq();renderGallery();renderLb();renderStaff();renderCharacters();renderMap();renderBanner();
  updateAdminAppCount(); // Admin panelindeki başvuru sekmesi için sayacı güncelle
}
function setText(id,v){const e=document.getElementById(id);if(e)e.textContent=v}
function setHref(id,v){const e=document.getElementById(id);if(e)e.href=v}

function renderStats(){
  const g=document.getElementById('stats-grid');g.innerHTML='';
  CONFIG.stats.forEach(s=>{
    const d=document.createElement('div');d.className='stat-card';
    d.innerHTML=`<div class="stat-num">${s.num}</div><div class="stat-label">${s.label}</div>`;
    g.appendChild(d);
  });
}

function renderAnn(){
  const l=document.getElementById('ann-list');l.innerHTML='';
  CONFIG.announcements.forEach(a=>{
    const d=document.createElement('div');d.className='ann-card';
    d.innerHTML=`<div class="ann-icon">${a.emoji}</div>
    <div class="ann-body"><div class="ann-date">${a.date}</div>
    <div class="ann-title">${a.title}</div><div class="ann-text">${a.text}</div></div>`;
    l.appendChild(d);
  });
}

function renderRules(){
  const l=document.getElementById('rules-list');l.innerHTML='';
  CONFIG.rules.forEach((r,i)=>{
    const d=document.createElement('div');d.className='rule-item';
    d.innerHTML=`<div class="rule-num">${String(i+1).padStart(2,'0')}</div>
    <div><div class="rule-cat">${r.cat}</div><div class="rule-text">${r.text}</div></div>`;
    l.appendChild(d);
  });
}

function renderFaq(){
  const l=document.getElementById('faq-list');l.innerHTML='';
  CONFIG.faq.forEach((f,i)=>{
    const d=document.createElement('div');d.className='faq-item';
    d.innerHTML=`<div class="faq-q" onclick="toggleFaq(this.parentElement)">${f.q}</div>
    <div class="faq-a">${f.a}</div>`;
    l.appendChild(d);
  });
}
function toggleFaq(el){el.classList.toggle('open')}

function renderGallery(){
  const g=document.getElementById('gallery-grid');g.innerHTML='';
  CONFIG.gallery.forEach((item,i)=>{
    const d=document.createElement('div');d.className='gallery-item';
    if(item.url){
      d.innerHTML=`<img src="${item.url}" alt="${item.label}" loading="lazy"/><div class="gallery-label">${item.label}</div>`;
      d.onclick=()=>{document.getElementById('lightbox-img').src=item.url;document.getElementById('lightbox').classList.add('open')};
    } else {
      d.innerHTML=`<div class="gallery-placeholder"><span>🖼️</span><span>${item.label}</span><span style="font-size:.65rem">URL ekle</span></div>`;
    }
    g.appendChild(d);
  });
}

function renderLb(){
  const b=document.getElementById('lb-body');b.innerHTML='';
  const rankClass=['gold','silver','bronze'];
  CONFIG.leaderboard.forEach((p,i)=>{
    const d=document.createElement('div');d.className='lb-row';
    const rc=rankClass[i]||'';
    d.innerHTML=`<div class="lb-rank ${rc}">${i===0?'🥇':i===1?'🥈':i===2?'🥉':i+1}</div>
    <div class="lb-player"><div class="lb-av" style="background:${p.color}">${p.name.charAt(0).toUpperCase()}</div><div class="lb-name">${p.name}</div></div>
    <div class="lb-score">${p.score.toLocaleString()}</div>
    <div class="lb-time">${p.time}</div>`;
    b.appendChild(d);
  });
}

function renderStaff(){
  const g=document.getElementById('staff-grid');g.innerHTML='';
  CONFIG.staff.forEach(s=>{
    const d=document.createElement('div');d.className='staff-card';
    d.innerHTML=`<div class="staff-av" style="background:${s.color}">${s.name.charAt(0).toUpperCase()}</div>
    <div class="staff-name">${s.name}</div><div class="staff-role" style="color:${s.color}">${s.role}</div>`;
    g.appendChild(d);
  });
}

/* =================== KARAKTERLER =================== */
function renderCharacters(){
  const g=document.getElementById('char-grid');if(!g)return;g.innerHTML='';
  CONFIG.characters.forEach(c=>{
    const d=document.createElement('div');d.className='char-card';
    d.style.setProperty('--cc',c.color);
    d.innerHTML=`<div class="char-emoji">${c.emoji}</div>
    <div class="char-name" style="color:${c.color}">${c.name}</div>
    <div class="char-desc">${c.desc}</div>
    <div class="char-slots" style="color:${c.color}">${c.slots}</div>`;
    // d.querySelector('.char-card::before'); // Bu satırın bir işlevi yok, kaldırılabilir
    d.style.borderTop=`3px solid ${c.color}`;
    g.appendChild(d);
  });
}

/* =================== HARİTA =================== */
function renderMap(){
  const b=document.getElementById('map-box');if(!b)return;
  if(CONFIG.mapUrl){
    b.innerHTML=`<img class="map-img" src="${CONFIG.mapUrl}" alt="Harita"/><div class="map-label">${CONFIG.mapLabel||''}</div>`;
  } else {
    b.innerHTML=`<div class="map-placeholder"><div class="mp-icon">🗺️</div><div class="mp-text">${CONFIG.mapLabel||'Harita'}</div><div style="font-size:.78rem;margin-top:4px">Admin panelinden harita görseli ekle</div></div>`;
  }
}

/* =================== BANNER =================== */
function renderBanner(){
  const dismissed=sessionStorage.getItem('banner_dismissed');
  if(dismissed === '1')return; // sessionStorage "1" string olarak saklar
  const ann=CONFIG.announcements;
  if(!ann||!ann.length)return;
  const latest=ann[0];
  const el=document.getElementById('ann-banner');
  const txt=document.getElementById('banner-text');
  if(txt)txt.textContent=`${latest.title} — ${latest.text.substring(0,60)}${latest.text.length>60?'...':''}`;
  if(el){setTimeout(()=>{el.classList.add('show');document.body.classList.add('banner-active');},800);}
}
function closeBanner(e){
  e.stopPropagation();
  const el=document.getElementById('ann-banner');
  el.classList.remove('show');
  document.body.classList.remove('banner-active');
  sessionStorage.setItem('banner_dismissed','1');
}
function scrollToDuyuru(){document.getElementById('duyurular').scrollIntoView({behavior:'smooth'});}

/* =================== TEMA =================== */
function toggleTheme(){
  document.body.classList.toggle('light');
  const isLight=document.body.classList.contains('light');
  document.getElementById('theme-btn').textContent=isLight?'🌙':'☀️';
  localStorage.setItem('dyrp_theme',isLight?'light':'dark');
}
function loadTheme(){
  const t=localStorage.getItem('dyrp_theme');
  if(t==='light'){document.body.classList.add('light');document.getElementById('theme-btn').textContent='🌙';}
  else{document.getElementById('theme-btn').textContent='☀️';}
}
function startApply(type){
  document.getElementById('apply-select-step').style.display='none';
  document.getElementById('form-moderator').style.display= type==='moderator'?'block':'none';
  document.getElementById('form-builder').style.display  = type==='builder'  ?'block':'none';
  document.getElementById('form-polis').style.display    = type==='polis'    ?'block':'none';
  document.getElementById('form-success').style.display='none'; // Başvuru başarı mesajını gizle
}
function backToSelect(){
  document.getElementById('apply-select-step').style.display='flex'; // Flex olarak ayarlandı
  document.getElementById('form-moderator').style.display='none';
  document.getElementById('form-builder').style.display='none';
  document.getElementById('form-polis').style.display='none';
  document.getElementById('form-success').style.display='none'; // Başvuru başarı mesajını gizle
}
function submitApply(e, role){
  e.preventDefault();
  const form=e.target;
  const data={role, tarih: new Date().toLocaleString('tr-TR'), cevaplar:{}};
  Array.from(form.elements).forEach(el=>{if(el.name)data.cevaplar[el.name]=el.value;});
  const apps=JSON.parse(localStorage.getItem('dyrp_apps')||'[]');
  apps.unshift(data);
  localStorage.setItem('dyrp_apps',JSON.stringify(apps));
  form.style.display='none';
  document.getElementById('apply-select-step').style.display='none';
  document.getElementById('form-success').style.display='block';
  updateAdminAppCount(); // Başvuru sayacını güncelle
}
function updateAdminAppCount(){
  const apps = JSON.parse(localStorage.getItem('dyrp_apps') || '[]');
  const countSpan = document.getElementById('admin-app-count');
  if(countSpan){
    if(apps.length > 0){
      countSpan.textContent = `(${apps.length})`;
      countSpan.style.color = 'var(--accent)';
      countSpan.style.marginRight = '5px';
    } else {
      countSpan.textContent = '';
    }
  }
}

/* =================== BAŞVURU ADMIN =================== */
function renderApplications(){
  const list=document.getElementById('ap-basvurular-list');
  if(!list)return;
  const apps=JSON.parse(localStorage.getItem('dyrp_apps')||'[]');
  if(!apps.length){list.innerHTML='<div class="app-empty">Henüz başvuru yok.</div>';return;}
  list.innerHTML='';
  const labelMap={
    roblox:'Roblox Adı',discord:'Discord Adı',yas:'Yaş',saat:'Günlük Saat',yil:'Studio Yılı',
    rdm:'RDM nedir?',hakaret:'Hakarete tepki?',failrp:'FailRP vs PowerGaming?',
    meta:'Metagaming nedir?',kavga:'Kavga çözümü?',neden:'Neden başvuruyorsun?',
    projeler:'Önceki projeler',araclar:'Kullandığı araçlar',sehir:'Şehir inşasında dikkat',optimizasyon:'Optimizasyon',
    deneyim:'Polis deneyimi',kovalama:'Kaçan şüpheli',silah:'Silah çeken kişi',
    gozalti:'Gözaltı prosedürü',sivil:'Sivile yaklaşım',ekip:'Ekip uyuşmazlığı'
  };
  apps.forEach((app,i)=>{
    const isBuilder=app.role==='Builder';
    const isPolis=app.role==='Polis'; // Polis rolü kontrolü
    const card=document.createElement('div');card.className='app-card';
    let qa='';
    Object.entries(app.cevaplar).forEach(([k,v])=>{
      if(!v)return;
      qa+=`<div class="app-q">${labelMap[k]||k}</div><div class="app-a">${v}</div>`;
    });
    card.innerHTML=`
      <div class="app-card-header">
        <div class="app-card-name">${app.cevaplar.roblox||app.cevaplar.discord||'?'}</div>
        <span class="app-card-role ${isBuilder?'builder':''} ${isPolis?'polis':''}">${app.role}</span>
      </div>
      <div class="app-card-date">${app.tarih}</div>
      <details><summary style="cursor:pointer;color:var(--muted);font-size:.85rem;margin-bottom:6px">Cevapları Gör ▸</summary>
      <div class="app-qa">${qa}</div></details>
      <div style="text-align:right;margin-top:10px">
        <button class="btn-remove" onclick="deleteApp(${i})">Sil</button>
      </div>`;
    list.appendChild(card);
  });
  updateAdminAppCount();
}
function deleteApp(i){
  const apps=JSON.parse(localStorage.getItem('dyrp_apps')||'[]');
  apps.splice(i,1);
  localStorage.setItem('dyrp_apps',JSON.stringify(apps));
  renderApplications();
}
function clearApplications(){
  if(confirm('Tüm başvurular silinecek. Emin misin?')){
    localStorage.removeItem('dyrp_apps');
    renderApplications();
  }
}

/* =================== MOBİL MENÜ =================== */
function toggleMenu(){document.getElementById('nav-links').classList.toggle('open')}
document.querySelectorAll('.nav-links a').forEach(a=>a.addEventListener('click',()=>document.getElementById('nav-links').classList.remove('open')));

/* =================== GİZLİ TETİKLEYİCİ =================== */
let _cc=0,_ct=null;
document.getElementById('secret-trigger').addEventListener('click',()=>{
  _cc++;clearTimeout(_ct);_ct=setTimeout(()=>_cc=0,1500);
  if(_cc>=5){_cc=0;const p=prompt('Yönetici şifresi:');if(p===window._pass)openAdmin();else if(p!==null)alert('Yanlış şifre!');}
});

/* =================== ADMİN PANELİ =================== */
function switchTab(name,btn){
  document.querySelectorAll('.admin-tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if (name === 'basvurular') { // Başvurular sekmesine geçince listeyi render et
    renderApplications();
  }
}

function openAdmin(){
  // Genel
  val('ap-gameName',CONFIG.gameName);val('ap-gameDesc',CONFIG.gameDesc);
  val('ap-ownerRoblox',CONFIG.ownerRoblox);val('ap-discordLink',CONFIG.discordLink);
  val('ap-robloxLink',CONFIG.robloxLink);val('ap-newpass','');
  // İstatistik
  renderListEdit('ap-stats', CONFIG.stats, s=>`
    <input type="text" value="${s.num}" placeholder="Rakam" data-f="num" style="max-width:90px"/>
    <input type="text" value="${s.label}" placeholder="Etiket" data-f="label"/>`);
  // Duyurular
  renderListEdit('ap-ann', CONFIG.announcements, a=>`
    <input type="text" value="${a.emoji}" placeholder="Emoji" style="max-width:54px" data-f="emoji"/>
    <input type="text" value="${a.date}" placeholder="Tarih" style="max-width:120px" data-f="date"/>
    <input type="text" value="${a.title}" placeholder="Başlık" data-f="title"/>
    <textarea data-f="text" placeholder="Metin">${a.text}</textarea>`);
  // Kurallar
  renderListEdit('ap-rules', CONFIG.rules, r=>`
    <input type="text" value="${r.cat}" placeholder="Kategori" style="max-width:110px" data-f="cat"/>
    <textarea data-f="text" placeholder="Kural metni">${r.text}</textarea>`);
  // SSS
  renderListEdit('ap-faq', CONFIG.faq, f=>`
    <textarea data-f="q" placeholder="Soru">${f.q}</textarea>
    <textarea data-f="a" placeholder="Cevap">${f.a}</textarea>`);
  // Galeri
  renderListEdit('ap-gallery', CONFIG.gallery, g=>`
    <input type="text" value="${g.url}" placeholder="Görsel URL" data-f="url"/>
    <input type="text" value="${g.label}" placeholder="Etiket" style="max-width:130px" data-f="label"/>`);
  // Liderlik
  renderListEdit('ap-lb', CONFIG.leaderboard, p=>`
    <input type="text" value="${p.name}" placeholder="Oyuncu adı" data-f="name"/>
    <input type="number" value="${p.score}" placeholder="Puan" style="max-width:90px" data-f="score"/>
    <input type="text" value="${p.time}" placeholder="Süre" style="max-width:90px" data-f="time"/>
    <input type="color" value="${p.color}" data-f="color"/>`);
  // Ekip
  renderListEdit('ap-staff', CONFIG.staff, s=>`
    <input type="text" value="${s.name}" placeholder="Kullanıcı adı" data-f="name"/>
    <input type="text" value="${s.role}" placeholder="Rol" style="max-width:130px" data-f="role"/>
    <input type="color" value="${s.color}" data-f="color"/>`);

  // Karakterler
  renderListEdit('ap-chars', CONFIG.characters, c=>`
    <input type="text" value="${c.emoji}" placeholder="Emoji" style="max-width:54px" data-f="emoji"/>
    <input type="text" value="${c.name}" placeholder="İsim" style="max-width:100px" data-f="name"/>
    <textarea data-f="desc" placeholder="Açıklama">${c.desc}</textarea>
    <input type="text" value="${c.slots}" placeholder="Slot" style="max-width:110px" data-f="slots"/>
    <input type="color" value="${c.color}" data-f="color"/>`);
  // Harita
  val('ap-mapUrl',  CONFIG.mapUrl||'');
  val('ap-mapLabel',CONFIG.mapLabel||'');

  document.getElementById('admin-panel').classList.add('open');
  renderApplications(); // Admin paneli açıldığında başvuruları da render et
}

function renderListEdit(containerId, arr, rowFn){
  const c=document.getElementById(containerId);c.innerHTML='';
  arr.forEach((item,i)=>{
    const row=document.createElement('div');row.className='list-row';row.dataset.idx=i;
    row.innerHTML=rowFn(item)+`<button class="btn-remove" onclick="removeRow('${containerId}',${i})">Sil</button>`;
    c.appendChild(row);
  });
}

function removeRow(containerId, idx){
  const map={
    'ap-stats':'stats','ap-ann':'announcements','ap-rules':'rules',
    'ap-faq':'faq','ap-gallery':'gallery','ap-lb':'leaderboard',
    'ap-staff':'staff','ap-chars':'characters'
  };
  const key=map[containerId];
  if(!key) return;

  // Duyurular, kurallar, SSS, karakterler için özellikle textarea içeriklerini doğru al
  const updatedList = Array.from(document.querySelectorAll(`#${containerId} .list-row`)).map(row => {
    if (containerId === 'ap-ann' || containerId === 'ap-rules' || containerId === 'ap-faq' || containerId === 'ap-chars') {
        const obj = {};
        Array.from(row.querySelectorAll('[data-f]')).forEach(input => {
            const field = input.dataset.f;
            obj[field] = input.tagName === 'TEXTAREA' ? input.value : input.value;
        });
        return obj;
    } else {
        const obj = {};
        Array.from(row.querySelectorAll('[data-f]')).forEach(input => {
            const field = input.dataset.f;
            obj[field] = input.value;
        });
        return obj;
    }
  });

  updatedList.splice(idx,1);
  CONFIG[key] = updatedList;

  // Sadece ilgili listeyi yeniden çiz, tüm paneli açma
  // 'renderCharsEdit()' yerine doğrudan renderListEdit'i çağır
  const activeTabName = document.querySelector('.admin-tab.active').dataset.tab;
  openAdmin(); // Tüm paneli yeniden açmak yerine sadece ilgili listeyi güncellemek daha iyi.
  switchTab(activeTabName, document.querySelector(`.admin-tab[onclick*="${activeTabName}"]`));
}


function addStat(){CONFIG.stats.push({num:'0',label:'Yeni'});openAdmin();document.querySelector('.admin-tab[onclick*="genel"]').click();}
function addAnn(){CONFIG.announcements.unshift({emoji:'📢',date:new Date().toLocaleDateString('tr-TR',{day:'numeric',month:'long',year:'numeric'}),title:'Yeni Duyuru',text:'Duyuru metni...'});openAdmin();document.querySelector('.admin-tab[onclick*="duyuru"]').click();}
function addRule(){CONFIG.rules.push({cat:'Genel',text:'Yeni kural...'});openAdmin();document.querySelector('.admin-tab[onclick*="kural"]').click();}
function addFaq(){CONFIG.faq.push({q:'Yeni soru?',a:'Cevap...'});openAdmin();document.querySelector('.admin-tab[onclick*="faq"]').click();}
function addGallery(){CONFIG.gallery.push({url:'',label:'Yeni'});openAdmin();document.querySelector('.admin-tab[onclick*="galeri"]').click();}
function addLb(){CONFIG.leaderboard.push({name:'Oyuncu',score:0,time:'0 saat',color:'#5865F2'});openAdmin();document.querySelector('.admin-tab[onclick*="lb"]').click();}
function addChar(){
  CONFIG.characters.push({emoji:'🧑',name:'Yeni',desc:'Açıklama...',slots:'Slot: ?',color:'#9b59b6'});
  openAdmin(); // Karakterler sekmesini aktif etmeden önce tüm admin panelini yeniden aç
  document.querySelector('.admin-tab[onclick*="karakter"]').click(); // Karakterler sekmesini aktif et
}
function addStaff(){CONFIG.staff.push({name:'Kullanici',role:'Destek',color:'#5865F2'});openAdmin();document.querySelector('.admin-tab[onclick*="ekip"]').click();}

function val(id,v){const e=document.getElementById(id);if(e)e.value=v;}
function gval(id){const e=document.getElementById(id);return e?e.value:'';}

function collectList(containerId, fields){
  const rows=document.querySelectorAll(`#${containerId} .list-row`);
  return Array.from(rows).map(row=>{
    const obj={};
    fields.forEach(f=>{
      const inp=row.querySelector(`[data-f="${f}"]`);
      if(inp){
        obj[f]=(f==='score'?parseInt(inp.value)||0:inp.value);
      } else {
        obj[f] = '';
      }
    });
    return obj;
  });
}

function saveAdmin(){
  CONFIG.gameName    = gval('ap-gameName')    || CONFIG.gameName;
  CONFIG.gameDesc    = gval('ap-gameDesc')    || CONFIG.gameDesc;
  CONFIG.ownerRoblox = gval('ap-ownerRoblox') || CONFIG.ownerRoblox;
  CONFIG.discordLink = gval('ap-discordLink') || CONFIG.discordLink;
  CONFIG.robloxLink  = gval('ap-robloxLink')  || CONFIG.robloxLink;

  CONFIG.stats         = collectList('ap-stats',  ['num','label']);
  CONFIG.announcements = collectList('ap-ann',    ['emoji','date','title','text']);
  CONFIG.rules         = collectList('ap-rules',  ['cat','text']);
  CONFIG.faq           = collectList('ap-faq',    ['q','a']);
  CONFIG.gallery       = collectList('ap-gallery',['url','label']);
  CONFIG.leaderboard   = collectList('ap-lb',     ['name','score','time','color']);
  CONFIG.staff         = collectList('ap-staff',  ['name','role','color']);

  CONFIG.characters   = collectList('ap-chars', ['emoji','name','desc','slots','color']);
  CONFIG.mapUrl       = gval('ap-mapUrl').trim();
  CONFIG.mapLabel     = gval('ap-mapLabel').trim();

  const np=gval('ap-newpass').trim();
  if(np){window._pass=np;localStorage.setItem('dyrp_pass',np);}

  localStorage.setItem('dyrp_cfg',JSON.stringify(CONFIG));
  applyConfig();
  closeAdmin();
}

function closeAdmin(){document.getElementById('admin-panel').classList.remove('open');}
document.getElementById('admin-panel').addEventListener('click',function(e){if(e.target===this)closeAdmin();});

