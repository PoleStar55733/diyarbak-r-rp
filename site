<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DiyarbakırRP</title>
  <link href="[fonts.googleapis.com](https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap)" rel="stylesheet"/>
  <style>
    :root {
      --accent:#e63946; --accent2:#ff6b35;
      --bg:#0a0a0f; --card:#12121a; --card2:#1a1a28;
      --border:#2a2a40; --text:#e8e8f0; --muted:#6b6b8a;
    }
    /* AYDINLIK TEMA */
    body.light{
      --bg:#f0f0f5; --card:#ffffff; --card2:#e8e8f0;
      --border:#d0d0e0; --text:#1a1a2e; --muted:#7a7a9a;
    }
    body.light::before{background:radial-gradient(ellipse 80% 50% at 20% 10%,rgba(230,57,70,.06) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 80%,rgba(255,107,53,.04) 0%,transparent 60%);}
    body.light nav{background:rgba(240,240,245,.92);}
    body.light .nav-links{background:var(--bg);}
    /* TEMA BUTONU */
    .theme-btn{background:none;border:1px solid var(--border);color:var(--text);border-radius:7px;padding:6px 11px;cursor:pointer;font-size:1rem;transition:border-color .2s;flex-shrink:0}
    .theme-btn:hover{border-color:var(--accent)}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Rajdhani',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
    body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 20% 10%,rgba(230,57,70,.12) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 80%,rgba(255,107,53,.08) 0%,transparent 60%);pointer-events:none;z-index:0}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:64px;background:rgba(10,10,15,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
    .nav-logo{font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:900;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:2px;white-space:nowrap}
    .nav-links{display:flex;gap:24px;flex-wrap:wrap}
    .nav-links a{color:var(--muted);text-decoration:none;font-size:.85rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;transition:color .2s}
    .nav-links a:hover{color:var(--accent)}
    .nav-menu-btn{display:none;background:none;border:1px solid var(--border);color:var(--text);border-radius:7px;padding:6px 12px;cursor:pointer;font-size:1.1rem}

    /* SECTIONS */
    section{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:80px 24px}
    .section-label{font-size:.75rem;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
    .section-title{font-family:'Orbitron',sans-serif;font-size:clamp(1.6rem,4vw,2.6rem);font-weight:900;margin-bottom:48px}
    .divider{width:100%;height:1px;background:var(--border)}

    /* BUTTONS */
    .btn{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:10px;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:.95rem;letter-spacing:1px;text-transform:uppercase;cursor:pointer;text-decoration:none;border:none;transition:transform .15s,box-shadow .15s}
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;box-shadow:0 4px 24px rgba(230,57,70,.35)}
    .btn-primary:hover{box-shadow:0 8px 32px rgba(230,57,70,.5)}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border)}
    .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
    .btn-discord{background:#5865F2;color:#fff;box-shadow:0 4px 24px rgba(88,101,242,.4)}
    .btn-discord:hover{box-shadow:0 8px 32px rgba(88,101,242,.6)}

    @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}

    /* HERO */
    .hero{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 60px}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(230,57,70,.12);border:1px solid rgba(230,57,70,.3);border-radius:999px;padding:6px 18px;font-size:.8rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:28px;animation:fadeUp .6s ease both}
    .hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulse 1.5s infinite}
    .hero h1{font-family:'Orbitron',sans-serif;font-size:clamp(2.8rem,10vw,6.5rem);font-weight:900;line-height:1;letter-spacing:-2px;background:linear-gradient(135deg,#fff 30%,var(--accent) 70%,var(--accent2) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:fadeUp .7s ease .1s both}
    .hero-sub{margin-top:20px;font-size:1.2rem;color:var(--muted);max-width:480px;animation:fadeUp .7s ease .2s both}
    .owner-chip{margin-top:36px;display:inline-flex;align-items:center;gap:12px;background:var(--card2);border:1px solid var(--border);border-radius:12px;padding:14px 28px;animation:fadeUp .7s ease .3s both}
    .owner-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:900;color:#fff}
    .owner-info{text-align:left}
    .owner-label{font-size:.7rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase}
    .owner-name{font-size:1.1rem;font-weight:700}
    .hero-btns{margin-top:48px;display:flex;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeUp .7s ease .4s both}

    /* BANNER */
    #ann-banner{position:fixed;top:64px;left:0;right:0;z-index:190;background:linear-gradient(90deg,var(--accent),var(--accent2));color:#fff;padding:9px 20px;display:flex;align-items:center;justify-content:center;gap:10px;font-size:.88rem;font-weight:600;letter-spacing:.5px;transform:translateY(-100%);transition:transform .4s ease;cursor:pointer}
    #ann-banner.show{transform:translateY(0)}
    #ann-banner .close-banner{margin-left:auto;background:none;border:none;color:#fff;cursor:pointer;font-size:1.1rem;opacity:.8;padding:0 4px}
    body.banner-active .hero{padding-top:160px}

    /* KARAKTERLEr */
    .char-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px}
    .char-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px 22px;transition:border-color .2s,transform .2s;position:relative;overflow:hidden}
    .char-card:hover{border-color:var(--accent);transform:translateY(-4px)}
    .char-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
    .char-emoji{font-size:2.4rem;margin-bottom:12px}
    .char-name{font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:900;margin-bottom:6px}
    .char-desc{color:var(--muted);font-size:.9rem;line-height:1.5;margin-bottom:14px}
    .char-slots{font-size:.72rem;letter-spacing:2px;text-transform:uppercase}

    /* HARİTA */
    .map-box{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;position:relative}
    .map-img{width:100%;display:block;max-height:520px;object-fit:cover}
    .map-placeholder{width:100%;height:360px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--muted)}
    .map-placeholder .mp-icon{font-size:3rem}
    .map-placeholder .mp-text{font-size:.85rem;letter-spacing:2px;text-transform:uppercase}
    .map-label{position:absolute;bottom:0;left:0;right:0;padding:18px 24px;background:linear-gradient(transparent,rgba(0,0,0,.85));font-size:.95rem;font-weight:700}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px}
    .stat-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px 20px;text-align:center;transition:border-color .2s,transform .2s}
    .stat-card:hover{border-color:var(--accent);transform:translateY(-4px)}
    .stat-num{font-family:'Orbitron',sans-serif;font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    .stat-label{font-size:.8rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:6px}

    /* DUYURULAR */
    .announcements-list{display:flex;flex-direction:column;gap:16px}
    .ann-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:24px 28px;display:flex;gap:20px;align-items:flex-start;transition:border-color .2s}
    .ann-card:hover{border-color:var(--accent)}
    .ann-icon{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
    .ann-body{}
    .ann-date{font-size:.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
    .ann-title{font-size:1.1rem;font-weight:700;margin-bottom:6px}
    .ann-text{color:var(--muted);font-size:.95rem;line-height:1.5}

    /* KURALLAR */
    .rules-list{display:flex;flex-direction:column;gap:12px;counter-reset:rule}
    .rule-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px 24px;display:flex;gap:16px;align-items:flex-start;transition:border-color .2s}
    .rule-item:hover{border-color:var(--accent)}
    .rule-num{font-family:'Orbitron',sans-serif;font-size:1.4rem;font-weight:900;color:var(--accent);min-width:32px;flex-shrink:0;line-height:1}
    .rule-text{font-size:1rem;line-height:1.5;color:var(--text)}
    .rule-cat{font-size:.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}

    /* SSS */
    .faq-list{display:flex;flex-direction:column;gap:10px}
    .faq-item{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .2s}
    .faq-item.open{border-color:var(--accent)}
    .faq-q{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;cursor:pointer;font-size:1rem;font-weight:700;gap:12px}
    .faq-q::after{content:'▸';color:var(--accent);transition:transform .2s;flex-shrink:0}
    .faq-item.open .faq-q::after{transform:rotate(90deg)}
    .faq-a{display:none;padding:0 24px 20px;color:var(--muted);line-height:1.6;font-size:.95rem}
    .faq-item.open .faq-a{display:block}

    /* GALERİ */
    .gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .gallery-item{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;aspect-ratio:16/9;cursor:pointer;transition:transform .2s,border-color .2s;position:relative}
    .gallery-item:hover{transform:scale(1.02);border-color:var(--accent)}
    .gallery-item img{width:100%;height:100%;object-fit:cover}
    .gallery-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--muted);font-size:2rem}
    .gallery-placeholder span{font-size:.8rem;letter-spacing:2px;text-transform:uppercase}
    .gallery-label{position:absolute;bottom:0;left:0;right:0;padding:10px 14px;background:linear-gradient(transparent,rgba(0,0,0,.8));font-size:.85rem;font-weight:600}

    /* LİDERLİK */
    .leaderboard{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden}
    .lb-header{display:grid;grid-template-columns:60px 1fr 120px 120px;padding:14px 24px;font-size:.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)}
    .lb-row{display:grid;grid-template-columns:60px 1fr 120px 120px;padding:16px 24px;border-bottom:1px solid var(--border);align-items:center;transition:background .15s}
    .lb-row:last-child{border-bottom:none}
    .lb-row:hover{background:rgba(255,255,255,.03)}
    .lb-rank{font-family:'Orbitron',sans-serif;font-size:1rem;font-weight:900}
    .lb-rank.gold{color:#f1c40f} .lb-rank.silver{color:#bdc3c7} .lb-rank.bronze{color:#cd7f32}
    .lb-player{display:flex;align-items:center;gap:12px}
    .lb-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:.85rem;font-weight:900;color:#fff}
    .lb-name{font-weight:700}
    .lb-score{font-family:'Orbitron',sans-serif;font-size:.95rem;font-weight:700;color:var(--accent);text-align:right}
    .lb-time{font-size:.85rem;color:var(--muted);text-align:right}

    /* BAŞVURU */
    .apply-box{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:48px 40px;max-width:640px;margin:0 auto}
    .apply-box h3{font-family:'Orbitron',sans-serif;font-size:1.4rem;margin-bottom:8px}
    .apply-box .sub{color:var(--muted);margin-bottom:32px;line-height:1.5}
    .form-group{margin-bottom:20px}
    .form-group label{display:block;font-size:.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
    .form-group input,.form-group textarea,.form-group select{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:12px 16px;color:var(--text);font-family:'Rajdhani',sans-serif;font-size:1rem;outline:none;transition:border-color .2s;resize:vertical}
    .form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--accent)}
    .form-group textarea{min-height:100px}
    .form-success{display:none;text-align:center;padding:32px;color:#2ecc71;font-size:1.1rem;font-weight:700}

    /* DESTEK EKİBİ */
    .staff-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px}
    .staff-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px 20px;text-align:center;transition:border-color .2s,transform .2s}
    .staff-card:hover{border-color:var(--accent);transform:translateY(-4px)}
    .staff-av{width:60px;height:60px;border-radius:50%;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:1.3rem;font-weight:900;color:#fff}
    .staff-name{font-size:1.05rem;font-weight:700}
    .staff-role{font-size:.78rem;letter-spacing:1.5px;text-transform:uppercase;margin-top:4px}

    /* DİSCORD */
    .discord-box{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:60px 40px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:24px}
    .discord-icon{width:72px;height:72px;background:#5865F2;border-radius:20px;display:flex;align-items:center;justify-content:center}
    .discord-icon svg{width:42px;height:42px;fill:#fff}
    .discord-box h3{font-family:'Orbitron',sans-serif;font-size:1.6rem;font-weight:900}
    .discord-box p{color:var(--muted);max-width:420px;line-height:1.6}

    /* FOOTER */
    footer{position:relative;z-index:1;border-top:1px solid var(--border);text-align:center;padding:32px 24px;color:var(--muted);font-size:.88rem}
    footer span{color:var(--accent)}

    /* LIGHTBOX */
    #lightbox{display:none;position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.92);align-items:center;justify-content:center;cursor:pointer}
    #lightbox.open{display:flex}
    #lightbox img{max-width:90vw;max-height:85vh;border-radius:12px;object-fit:contain}

    /* ADMIN PANEL */
    #admin-panel{display:none;position:fixed;inset:0;z-index:999;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);align-items:center;justify-content:center}
    #admin-panel.open{display:flex}
    .admin-box{background:var(--card2);border:1px solid var(--border);border-radius:20px;padding:36px;width:100%;max-width:780px;/* Genişliği artırıldı */ max-height:90vh;overflow-y:auto;
        /* Scrollbar stilini mevcut temaya uyduruldu */
        scrollbar-width: thin;
        scrollbar-color: var(--accent) var(--card); /* Firefox */
    }
    .admin-box::-webkit-scrollbar {
        width: 8px;
    }
    .admin-box::-webkit-scrollbar-track {
        background: var(--card);
        border-radius: 10px;
    }
    .admin-box::-webkit-scrollbar-thumb {
        background-color: var(--accent);
        border-radius: 10px;
        border: 2px solid var(--card);
    }

    .admin-box h2{font-family:'Orbitron',sans-serif;font-size:1.3rem;margin-bottom:6px;color:var(--accent)}
    .admin-tabs{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap;margin-top:16px;border-bottom:1px solid var(--border);padding-bottom:12px;}
    .admin-tab{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:7px 16px;cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:.85rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;transition:all .2s;flex-shrink:0;}
    .admin-tab:hover{border-color:var(--accent);color:var(--accent);}
    .admin-tab.active{background:var(--accent);border-color:var(--accent);color:#fff}
    .admin-tab-content{display:none}
    .admin-tab-content.active{display:block}
    .admin-section{margin-bottom:20px}
    .admin-section label{display:block;font-size:.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:7px}
    .admin-section input,.admin-section textarea,.admin-section select{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:12px 16px;color:var(--text);font-family:'Rajdhani',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;resize:vertical}
    .admin-section input:focus,.admin-section textarea:focus,.admin-section select:focus{border-color:var(--accent)}
    .form-group textarea{min-height:70px;} /* Admin paneli için textarea yüksekliği ayarı */
    .list-edit{display:flex;flex-direction:column;gap:8px;margin-bottom:10px}
    .list-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:8px 12px;}
    .list-row input, .list-row select{flex:1;min-width:80px;padding:8px 12px;background:var(--bg);border:1px solid var(--border);border-radius:6px;font-size:.9rem;}
    .list-row input[type="color"]{width:38px;padding:2px;flex-shrink:0;height:38px;}
    .btn-remove{background:rgba(230,57,70,.15);border:1px solid var(--accent);color:var(--accent);border-radius:7px;padding:7px 11px;cursor:pointer;font-size:.82rem;font-family:'Rajdhani',sans-serif;font-weight:700;flex-shrink:0;transition:all .2s;}
    .btn-remove:hover{background:var(--accent);color:#fff;}
    .btn-add{background:transparent;border:1px dashed var(--border);color:var(--muted);border-radius:8px;padding:9px;cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:.88rem;width:100%;transition:border-color .2s,color .2s}
    .btn-add:hover{border-color:var(--accent);color:var(--accent)}
    .admin-btns{display:flex;gap:12px;justify-content:flex-end;margin-top:24px;padding-top:20px;border-top:1px solid var(--border)}

    #secret-trigger{position:fixed;bottom:0;right:0;width:60px;height:60px;z-index:500;cursor:default}

    /* BAŞVURU KARTLARI */
    .app-card{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:12px}
    .app-card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
    .app-card-name{font-weight:700;font-size:1rem}
    .app-card-role{font-size:.72rem;letter-spacing:2px;text-transform:uppercase;padding:3px 10px;border-radius:999px;background:rgba(230,57,70,.15);color:var(--accent)}
    .app-card-role.builder{background:rgba(255,107,53,.15);color:var(--accent2)}
    .app-card-role.polis{background:rgba(52,152,219,.15);color:#3498db;} /* Polis rolü için renk */
    .app-card-date{font-size:.72rem;color:var(--muted);margin-bottom:10px}
    .app-qa{margin-top:6px}
    .app-q{font-size:.75rem;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-top:8px}
    .app-a{font-size:.9rem;color:var(--text);line-height:1.4}
    .app-empty{text-align:center;color:var(--muted);padding:32px;font-size:.95rem}

    /* MOBILE */
    @media(max-width:700px){
      nav{padding:0 16px}
      .nav-links{display:none;position:fixed;top:64px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);flex-direction:column;padding:20px 24px;gap:18px;z-index:199}
      .nav-links.open{display:flex}
      .nav-menu-btn{display:block}
      .lb-header,.lb-row{grid-template-columns:50px 1fr 80px}
      .lb-time{display:none}
      .apply-box{padding:28px 18px}
      .discord-box{padding:36px 18px}
      .admin-box{padding:20px 16px}
      .admin-tabs{flex-direction:column;gap:4px;}
